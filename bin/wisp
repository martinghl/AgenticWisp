#!/usr/bin/env bash
# AgenticWisp launcher:  up | down | status | signal <event> | watch [--simple] | install-hooks
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PY="${WISP_PYTHON:-python3}"
PORT="${WISP_PORT:-9099}"
export PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}"
RUN_DIR="$HOME/.agenticwisp"
LOG="$RUN_DIR/wispd.log"
PIDFILE="$RUN_DIR/wispd.pid"

running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; }

# Pick the first interpreter that can import `textual` (needed only by the fancy TUI lamp).
# Order: $WISP_PYTHON, a project-local virtualenv, then python3 / python on PATH.
find_tui_python() {
  local cand
  for cand in "${WISP_PYTHON:-}" "$HERE/.venv/bin/python" "$HERE/venv/bin/python" python3 python; do
    [ -z "$cand" ] && continue
    command -v "$cand" >/dev/null 2>&1 || continue
    if "$cand" -c "import textual" >/dev/null 2>&1; then echo "$cand"; return 0; fi
  done
  return 1
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  up)
    if running; then echo "hub already running (pid $(cat "$PIDFILE"))"; exit 0; fi
    mkdir -p "$RUN_DIR"
    WISP_PORT="$PORT" nohup "$PY" -m agenticwisp.wispd >"$LOG" 2>&1 &
    echo $! > "$PIDFILE"
    echo "hub started (pid $!), port $PORT, log $LOG"
    ;;
  down)
    if running; then kill "$(cat "$PIDFILE")" 2>/dev/null || true; fi
    rm -f "$PIDFILE"; echo "hub stopped"
    ;;
  status)
    if running; then
      s="$("$PY" -c "import urllib.request;print(urllib.request.urlopen('http://127.0.0.1:$PORT/state',timeout=2).read().decode().strip())" 2>/dev/null || echo '?')"
      echo "running (pid $(cat "$PIDFILE")), state: $s"
    else echo "not running"; fi
    ;;
  signal)
    # Hook client: pure stdlib, must never break Claude. Silently no-op if python is missing.
    if command -v "$PY" >/dev/null 2>&1; then
      exec "$PY" -m agenticwisp.signal "$@"
    fi
    exit 0
    ;;
  watch)
    if [ "${1:-}" = "--simple" ]; then
      shift; exec "$PY" -m agenticwisp.lamp "$@"   # stdlib-only fallback lamp (no textual)
    fi
    if tp="$(find_tui_python)"; then
      exec "$tp" -m agenticwisp.tui "$@"
    fi
    echo "No Python with 'textual' found." >&2
    echo "  Install it:   python3 -m pip install textual   (or: pip install '.[tui]')" >&2
    echo "  Or run the stdlib-only lamp:   wisp watch --simple" >&2
    exit 1
    ;;
  install-hooks)
    exec "$PY" -m agenticwisp.install_hooks "$HERE/bin/wisp" "$@"
    ;;
  *)
    echo "usage: wisp {up|down|status|signal <event>|watch [--simple]|install-hooks}"
    exit 1 ;;
esac
