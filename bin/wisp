#!/usr/bin/env bash
# AgenticWisp launcher — thin shim. All command logic lives in agenticwisp/cli.py.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="$HERE${PYTHONPATH:+:$PYTHONPATH}"
export WISP_LAUNCHER="$HERE/bin/wisp"   # absolute hook-command base for install-hooks

# Prefer an interpreter that already has textual (the fancy panel); else fall back.
pick_py() {
  local c
  for c in "${WISP_PYTHON:-}" "$HERE/.venv/bin/python" "$HERE/venv/bin/python" python3 python; do
    [ -z "$c" ] && continue
    command -v "$c" >/dev/null 2>&1 || continue
    if "$c" -c "import textual" >/dev/null 2>&1; then echo "$c"; return 0; fi
  done
  echo "${WISP_PYTHON:-python3}"   # no textual anywhere: cli prints the hint for watch/demo
}

exec "$(pick_py)" -m agenticwisp.cli "$@"
